# ============================================
# AgentHub 配置模板
# 复制为 .env 后按需修改
# ============================================

# ── App ──
APP_NAME=AgentHub
DEBUG=false

# ── Database ──
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub@localhost:5432/agenthub

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Security ──
# 生产环境务必使用强随机字符串
SECRET_KEY=change-me-to-a-256-bit-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Docker ──
DOCKER_HOST=unix:///var/run/docker.sock
HERMES_BASE_IMAGE=agenthub/hermes-base:latest
TENANT_NETWORK=agenthub-tenant

# ── Model Proxy ──
MODEL_PROXY_ENABLED=true
# 平台统一代理 OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-...

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000

# ── Billing ──
# Stripe (Phase 2)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
